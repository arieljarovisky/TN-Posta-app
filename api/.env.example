# Port where the backend will run
PORT=8000

# for latam https://www.tiendanube.com/apps/authorize/token
# for BR https://www.nuvemshop.com.br/apps/authorize/token
TIENDANUBE_AUTENTICATION_URL=https://www.tiendanube.com/apps/authorize/token

# for latam https://api.tiendanube.com/v1
# for br https://api.nuvemshop.com.br/v1
TIENDANUBE_API_URL=https://api.nuvemshop.com.br/v1

# App settings
# You client secret for app
CLIENT_SECRET=

# You app id
CLIENT_ID=

# Your Partners Portal account email
CLIENT_EMAIL=

# In Developer Mode the value must be THE_SECRET
# In Production environment the value must be the client_secret of your app
SECRET_KEY=THE_SECRET

# Required app permissions in Partners Portal (Shipping section):
# - Edit Shipping (API scope: write_shipping) — publish rates to checkout
# - read_orders / write_orders — manage orders
# - read_content / write_content — crear pagina de seguimiento automaticamente
# - write_scripts — activar script de seguimiento en la tienda (opcional)

# Handle de la pagina en Tiendanube (default: seguimiento-de-envios)
# TRACKING_PAGE_HANDLE=seguimiento-de-envios

# ID del script registrado en Partners Portal (solo si NO es auto-instalable)
# TRACKING_STOREFRONT_SCRIPT_ID=

# Public URL of your deployed app (HTTPS). Used for Tiendanube shipping callback.
# APP_PUBLIC_URL=https://tn-posta-app-production.up.railway.app
APP_PUBLIC_URL=

# Store slug — subdominio de la tienda en mitiendanube.com (ej. lupo15)
# STORE_SLUG=lupo15
STORE_SLUG=

# Optional: full admin URL to open the app (overrides STORE_SLUG)
# STORE_ADMIN_URL=https://lupo15.mitiendanube.com/admin/v2/apps/35321
STORE_ADMIN_URL=

# Optional: fallback shipping names (comma separated) if not configured in app UI
# SHIPPING_OPTION_NAMES=Envios Posta,Envio CABA/GBA

# Optional: persistent database path (recommended on Railway)
# Persistencia en Railway (obligatorio en produccion):
# 1. Service → Volumes → Add Volume → mount path /data
# 2. Variables:
DATABASE_PATH=/data/db.json
